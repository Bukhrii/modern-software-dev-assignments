<div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 group">
  <!-- View mode -->
  <div class="task-view-<%= task.id %>">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="text-sm font-semibold text-slate-800 leading-snug flex-1"><%= task.title %></h3>
      <% 
        var badgeClass = task.status === 'to-do' ? 'status-badge-todo' : task.status === 'in-progress' ? 'status-badge-inprog' : 'status-badge-done';
        var badgeLabel = task.status === 'to-do' ? 'To Do' : task.status === 'in-progress' ? 'In Progress' : 'Done';
      %>
      <span class="text-xs font-medium px-2 py-0.5 rounded-full flex-shrink-0 <%= badgeClass %>"><%= badgeLabel %></span>
    </div>
    <% if (task.description) { %>
      <p class="text-xs text-slate-500 mb-3 leading-relaxed"><%= task.description %></p>
    <% } %>

    <!-- Status change -->
    <form method="POST" action="/tasks/<%= task.id %>/status" class="mb-2">
      <div class="flex gap-2">
        <select name="status" class="flex-1 text-xs px-2 py-1.5 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400 bg-slate-50 text-slate-600">
          <option value="to-do"       <%= task.status === 'to-do'        ? 'selected' : '' %>>To Do</option>
          <option value="in-progress" <%= task.status === 'in-progress'  ? 'selected' : '' %>>In Progress</option>
          <option value="done"        <%= task.status === 'done'         ? 'selected' : '' %>>Done</option>
        </select>
        <button type="submit" class="text-xs px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-600 font-medium rounded-lg transition-colors">
          Update
        </button>
      </div>
    </form>

    <!-- Edit & Delete buttons -->
    <div class="flex gap-2 mt-1">
      <button
        onclick="document.getElementById('edit-<%= task.id %>').classList.toggle('hidden'); document.querySelector('.task-view-<%= task.id %>').classList.toggle('hidden')"
        class="text-xs text-indigo-600 hover:text-indigo-800 font-medium"
      >
        Edit
      </button>
      <form method="POST" action="/tasks/<%= task.id %>/delete" class="ml-auto" onsubmit="return confirm('Delete this task?')">
        <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-medium">
          Delete
        </button>
      </form>
    </div>
  </div>

  <!-- Edit mode (hidden by default) -->
  <div id="edit-<%= task.id %>" class="hidden">
    <form method="POST" action="/tasks/<%= task.id %>/edit" class="flex flex-col gap-2">
      <div>
        <label class="block text-xs font-medium text-slate-500 mb-1">Title <span class="text-red-500">*</span></label>
        <input
          type="text"
          name="title"
          value="<%= task.title %>"
          required
          class="w-full text-sm px-2 py-1.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400"
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-500 mb-1">Description</label>
        <input
          type="text"
          name="description"
          value="<%= task.description %>"
          class="w-full text-sm px-2 py-1.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400"
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
        <select name="status" class="w-full text-sm px-2 py-1.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="to-do"       <%= task.status === 'to-do'       ? 'selected' : '' %>>To Do</option>
          <option value="in-progress" <%= task.status === 'in-progress' ? 'selected' : '' %>>In Progress</option>
          <option value="done"        <%= task.status === 'done'        ? 'selected' : '' %>>Done</option>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="flex-1 text-xs px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors">
          Save
        </button>
        <button
          type="button"
          onclick="document.getElementById('edit-<%= task.id %>').classList.add('hidden'); document.querySelector('.task-view-<%= task.id %>').classList.remove('hidden')"
          class="flex-1 text-xs px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-600 font-medium rounded-lg transition-colors"
        >
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>
